{
  "manifest_version": 3,
  "name": "Twitch Ad Silencer",
  "version": "1.2.0",
  "description": "During a Twitch ad break, unmutes the live stream preview and mutes the ad on the current tab, so only the stream audio is heard.",
  "browser_specific_settings": {
    "gecko": {
      "id": "twitch-ad-silencer@ybeneito",
      "strict_min_version": "121.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["storage"],
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "action": {
    "default_title": "Twitch Ad Silencer",
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon.svg"
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
